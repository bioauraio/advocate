# === Telegram-бот агента-юриста ===
# Токен и username бота из @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AA...
TELEGRAM_BOT_USERNAME=my_lawyer_bot

# Кто может пользоваться ботом: Telegram user id через запятую.
# Свой id бот покажет в ответе неавторизованному пользователю.
ALLOWED_USERS=111111111
# Необязательно: id групповых чатов, все участники которых авторизованы без whitelist.
# ВНИМАНИЕ: при повышении группы до супергруппы Telegram меняет chat_id на -100…
#ALLOWED_CHATS=-1001234567890

# Рабочая папка агента (песочница): CLAUDE.md, knowledge/, cases/, uploads/
APPROVED_DIRECTORY=/opt/lawyer-agent/workspace

# === Claude ===
# Вариант 1 (рекомендуется): подписка Claude Pro/Max — выполни `claude auth login`
# под тем же пользователем, что запускает бота, и оставь ANTHROPIC_API_KEY пустым.
# Вариант 2: API-ключ Anthropic (платно по токенам).
USE_SDK=true
ANTHROPIC_API_KEY=
CLAUDE_CLI_PATH=/usr/bin/claude
CLAUDE_MAX_TURNS=20
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_COST_PER_USER=1000.0
CLAUDE_MAX_COST_PER_REQUEST=50.0

# Инструменты агента: чтение базы знаний, создание документов, отправка файлов в чат.
CLAUDE_ALLOWED_TOOLS=Read,Glob,Grep,LS,Write,Edit,mcp__telegram__send_image_to_user,mcp__telegram__send_file_to_user
DISABLE_TOOL_VALIDATION=false
DISABLE_SECURITY_PATTERNS=false

# === Режим ===
AGENTIC_MODE=true
VERBOSE_LEVEL=0

# === Rate limiting ===
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=30

# === Хранилище сессий ===
DATABASE_URL=sqlite:///data/bot.db
SESSION_TIMEOUT_HOURS=72
MAX_SESSIONS_PER_USER=5

# === Фичи ===
ENABLE_FILE_UPLOADS=true
ENABLE_IMAGE_UPLOADS=false
ENABLE_VOICE_MESSAGES=false
ENABLE_GIT_INTEGRATION=false
ENABLE_QUICK_ACTIONS=false
ENABLE_CONVERSATION_MODE=true
ENABLE_PROJECT_THREADS=false
# MCP-сервер telegram — отправка файлов/картинок из агента в чат
ENABLE_MCP=true
MCP_CONFIG_PATH=/opt/lawyer-agent/bot/mcp_config.json
ENABLE_API_SERVER=false
ENABLE_SCHEDULER=false

# === Мониторинг ===
LOG_LEVEL=INFO
ENVIRONMENT=production
DEBUG=false
DEVELOPMENT_MODE=false

# === Прокси (опционально) ===
# Если сервер стоит там, где api.anthropic.com или api.telegram.org недоступны
# напрямую — укажи HTTP-прокси, напр. http://127.0.0.1:8118
#HTTP_PROXY=
#HTTPS_PROXY=
